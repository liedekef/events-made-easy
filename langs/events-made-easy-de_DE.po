#: includes/eme-options.php:2186
msgid "The port to connect to your IMAP server. Typical ports are 143 (no encryption) and 993 (SSL)."
msgstr "Der Port für die Verbindung zu Ihrem IMAP-Server. Typische Ports sind 143 (keine Verschlüsselung) und 993 (SSL)."

#: includes/eme-options.php:2188
msgid "IMAP encryption"
msgstr "IMAP-Verschlüsselung"

#: includes/eme-options.php:2195
