msgid "Updated member email body"
msgstr "E-Mail-Text: Mitglied aktualisiert"

#: includes/eme-members.php:2371
msgid "The body of the mail sent to the member upon changes."
msgstr "Der E-Mail-Text der Nachricht, die dem Mitglied bei Änderungen zugestellt wird."

#: includes/eme-members.php:2395
msgid "Membership extended email"
msgstr "Mitgliedschaft verlängert E-Mail"

#: includes/eme-members.php:2397
