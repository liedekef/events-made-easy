#: eme-options.php:2417
msgid "Frontend Event Submit Notification Email"
msgstr "Email s upozornením odoslanie podujatia cez klientske rozhranie"

#: eme-options.php:2421
msgid "Contact Person New Event Email Subject"
msgstr "Predmet emailu o novom podujatí pre kontaktnú osobu"

#: eme-options.php:2421
msgid "The subject of the email that will be sent to the contact person when a new event is submitted."
msgstr "Predmet e-mailu, ktorý sa odošle kontaktnej osobe po odoslaní nového podujatia."

#: eme-options.php:2422
msgid "Contact Person New Event Email Body"
msgstr "Telo emailu o novom podujatí pre kontaktnú osobu"

#: eme-options.php:2422
msgid "The body of the email that will be sent to the contact person when a new event is submitted."
msgstr "Telo e-mailu, ktorý sa odošle kontaktnej osobe po odoslaní novej udalosti."

#: eme-options.php:2423
msgid "Author Payment Notification Email Subject"
msgstr "Predmet emailu o oznámení platby pre autora"

#: eme-options.php:2423
msgid "The subject of the email that will be sent to the event author (the creator normally) when a payment notification is received via a payment gateway."
msgstr "Predmet e-mailu, ktorý sa odošle autorovi podujatia (zvyčajne tvorcovi) po prijatí oznámenia o platbe prostredníctvom platobnej brány."

#: eme-options.php:2424
msgid "Author Payment Notification Email Body"
msgstr "Telo emailu o oznámení platby pre autora"

#: eme-options.php:2424
msgid "The body of the email that will be sent to the event author (the creator normally) when a payment notification is received via a payment gateway."
msgstr "Telo e-mailu, ktorý sa odošle autorovi podujatia (zvyčajne tvorcovi) po prijatí oznámenia o platbe prostredníctvom platobnej brány."

#: eme-options.php:2428
msgid "Event paid mail attachments"
msgstr "Prílohy emailu o platbe za podujatie"

#: eme-options.php:2450
msgid "Optionally add attachments to the mail when an event is paid for."
msgstr "Voliteľne pridajte prílohy k emailu, keď je podujatie zaplatené."

#: eme-options.php:2468
msgid "Mailing group subscription Email"
msgstr "Prihlasovací email mailingovej skupiny"

#: eme-options.php:2472
msgid "Subscribe email subject"
msgstr "Predmet emailu odberu noviniek"

#: eme-options.php:2472
msgid "The subject of the email that will be sent to the person asking to subscribe to a mailing group."
msgstr "Predmet emailu, ktorý sa pošle osobe, ktorá žiada o prihlásenie sa na odber emailovej skupiny."

#: eme-options.php:2472
#: eme-options.php:2500
#: eme-options.php:2502
#: eme-options.php:2633
#: eme-options.php:2635
#: eme-options.php:2636
#: eme-options.php:2638
#: eme-options.php:2640
#: eme-options.php:2641
#: eme-options.php:2642
#: eme-options.php:2644
msgid "No placeholders can be used."
msgstr "Nie je možné použiť žiadne zástupné výrazy."

#: eme-options.php:2473
msgid "Subscribe email body"
msgstr "Telo emailu odberu noviniek"

#: eme-options.php:2473
msgid "The body of the email that will be sent to the person asking to subscribe to a mailing group."
msgstr "Telo emailu, ktorý sa odošle osobe, ktorá žiada o prihlásenie na odber mailovej skupiny."

#: eme-options.php:2473
msgid "Should contain at least the placeholder #_SUB_CONFIRM_URL (if this placeholder is not present, people will not be able to confirm their subscription). Next to that, #_LASTNAME and #_FIRSTNAME can also be used. You should also advise the person that this subscription confirmation link is only valid for a specific amount of time (typically one day)."
msgstr "Mal by obsahovať aspoň zástupný výraz #_SUB_CONFIRM_URL (ak tento zástupný výraz nie je prítomný, ľudia nebudú môcť potvrdiť svoj odber). Okrem toho je možné použiť aj #_LASTNAME a #_FIRSTNAME. Mali by ste tiež upozorniť osobu, že tento odkaz na potvrdenie odberu je platný len určitý čas (zvyčajne jeden deň)."

#: eme-options.php:2475
msgid "Subscribe mail attachments"
msgstr "Prílohy prihlasovacieho emailu"

#: eme-options.php:2497
msgid "Optionally add attachments to the mail when someone subscribes to a mailing group."
msgstr "Voliteľne pridajte prílohy k emailu, keď sa niekto prihlási na odber noviniek."

#: eme-options.php:2500
msgid "Unsubscribe email subject"
msgstr "Predmet odhlasovacieho emailu"

#: eme-options.php:2500
msgid "The subject of the email that will be sent to the person asking to unsubscribe."
msgstr "Predmet emailu, ktorý sa odošle osobe, ktorá žiada o odhlásenie z odberu."

#: eme-options.php:2501
msgid "Unsubscribe email body"
msgstr "Telo odhlasovacieho emailu"

#: eme-options.php:2501
msgid "The body of the email that will be sent to the person asking to unsubscribe."
msgstr "Telo emailu, ktorý sa odošle osobe, ktorá žiada o odhlásenie z odberu."

#: eme-options.php:2501
msgid "Can contain all people placeholders and one additional required placeholder, namely #_UNSUB_CONFIRM_URL (which will be replaced with the unsubscribe confirmation url)."
msgstr "Môže obsahovať zástupné výrazy všetkých ľudí a jeden ďalší požadovaný zástupný výraz, a to #_UNSUB_CONFIRM_URL (ktorý bude nahradený URL adresou na potvrdenie zrušenia prihlásenia)."

#: eme-options.php:2514
#: eme-tasks.php:703
msgid "Task Signup Pending Email Subject"
msgstr "Predmet emailu o čakajúcej registrácii na úlohu"

#: eme-options.php:2514
