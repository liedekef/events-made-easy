msgstr "Telo e-mailu s pripomienkou, ktorý bude odoslaný príjemcovi."

#: eme-options.php:2556
#: eme-tasks.php:768
msgid "Task Signup Cancelled Email Subject"
msgstr "Predmet emailu o zrušenom prihlásení na úlohu"

#: eme-options.php:2556
