msgid "Individual map zoom factor"
msgstr "单独的地图缩放系数"

#: includes/eme-options.php:3245
msgid "The zoom factor used when showing a single map (max: 14)."
msgstr "显示单项地图时使用的缩放系数（最大：14）。"

#: includes/eme-options.php:3246
msgid "Default location map icon"
msgstr "默认的位置地图图标"

#: includes/eme-options.php:3247
msgid "Default location balloon format"
msgstr "默认地点气球格式"

#: includes/eme-options.php:3247
