# =============================================================================
# WP.org Release Ignore List
#
# Files and directories listed here are stripped from the WP.org release build.
# Used by eme_wp_release.sh. One pattern per line.
#
# Lines starting with # are comments. Empty lines are ignored.
# =============================================================================


# =============================================================================
# SECTION 1: Plugin root — GitHub-only files
# =============================================================================
# Exact paths relative to plugin root. Trailing / = directory.
# WP.org only reads readme.txt. LICENSE is kept.

.gitignore
.github/
README.md
CONTRIBUTING.md
CODE_OF_CONDUCT.md
SECURITY.md
credits.txt
changelog.txt


# =============================================================================
# SECTION 2: GitHub updater — not needed on WP.org
# =============================================================================
# The updater class file. The require_once + Update URI header in
# events-manager.php are patched out by the script automatically.

class-eme-updater.php


# =============================================================================
# SECTION 3: Dev/build directories
# =============================================================================

script/
dist/


# =============================================================================
# SECTION 4: Language source files
# =============================================================================
# Keep compiled translations (.mo, .l10n.php) for bundled language support.
# Source files (.po, .pot) are not needed — WP.org generates its own.

langs/*.po
langs/*.pot
langs/gettextize.sh
langs/pot_gen/


# =============================================================================
# SECTION 5: Vendor cleanup
# =============================================================================
# Third-party SDKs ship with examples, tests, docs, CI configs, and metadata
# that are not needed at runtime. Stripping these reduces the release size
# and eliminates ~230 PCP errors.
#
# Each [vendor-cleanup] block specifies:
#   path:    which vendor directory to clean (relative to plugin root)
#   dirs:    directory names to remove (case-insensitive, recursive)
#   files:   filenames to remove (exact match, recursive)
#   hidden:  yes = remove all dotfiles/dotdirs (.gitignore, .github/, etc.)
#   keep:    paths to preserve even if they match a strip rule (relative to path)

[vendor-cleanup]
path:   payment_gateways
dirs:   Examples examples samples tests test docs doc
files:  README.md README.txt readme.txt CHANGELOG.md CHANGES.md UPGRADING.md CONTRIBUTING.md phpunit.xml phpunit.xml.dist phpstan.neon phpstan.neon.dist Makefile .travis.yml composer.lock
hidden: yes
keep:   braintree/vendor/braintree/braintree_php/lib/Braintree/Test

[vendor-cleanup]
path:   dompdf
dirs:   Examples examples samples tests test docs doc
files:  README.md README.txt readme.txt CHANGELOG.md CHANGES.md UPGRADING.md CONTRIBUTING.md phpunit.xml phpunit.xml.dist phpstan.neon phpstan.neon.dist Makefile .travis.yml composer.lock
hidden: yes
